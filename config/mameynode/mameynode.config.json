{
  "$schema": "https://ierahkwa.io/schemas/mameynode-v3.3.0.json",
  "name": "MameyNode",
  "version": "3.3.0",
  "description": "Runtime soberano Node.js para la plataforma Ierahkwa — optimizado para 574 naciones tribales",
  "runtime": {
    "engine": "node",
    "version": "20.11.0-lts",
    "mode": "cluster",
    "workers": "auto",
    "maxMemoryPerWorker": "512MB",
    "gracefulShutdownTimeout": 30000
  },
  "cluster": {
    "enabled": true,
    "strategy": "round-robin",
    "workers": {
      "min": 2,
      "max": 16,
      "autoScale": true,
      "scaleUpThreshold": 0.75,
      "scaleDownThreshold": 0.25
    },
    "healthCheck": {
      "interval": 10000,
      "timeout": 5000,
      "unhealthyThreshold": 3,
      "restartOnFailure": true
    }
  },
  "networking": {
    "host": "0.0.0.0",
    "port": 3000,
    "backlog": 511,
    "keepAliveTimeout": 65000,
    "headersTimeout": 66000,
    "maxHeaderSize": 16384,
    "http2": {
      "enabled": true,
      "allowHTTP1": true,
      "maxConcurrentStreams": 250
    },
    "tls": {
      "enabled": true,
      "certPath": "/etc/ierahkwa/tls/cert.pem",
      "keyPath": "/etc/ierahkwa/tls/key.pem",
      "minVersion": "TLSv1.3",
      "ciphers": "TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256"
    },
    "cors": {
      "enabled": true,
      "origins": ["https://*.ierahkwa.io", "https://*.ierahkwa.gov"],
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
      "credentials": true,
      "maxAge": 86400
    }
  },
  "gateway": {
    "proxy": {
      "enabled": true,
      "timeout": 30000,
      "retries": 3,
      "circuitBreaker": {
        "enabled": true,
        "threshold": 5,
        "timeout": 60000,
        "halfOpenMax": 3
      }
    },
    "rateLimiting": {
      "enabled": true,
      "windowMs": 60000,
      "maxRequests": 1000,
      "keyGenerator": "ip",
      "skipSuccessfulRequests": false,
      "tiers": {
        "public": { "maxRequests": 100, "windowMs": 60000 },
        "citizen": { "maxRequests": 500, "windowMs": 60000 },
        "admin": { "maxRequests": 5000, "windowMs": 60000 },
        "service": { "maxRequests": 50000, "windowMs": 60000 }
      }
    },
    "routes": {
      "orbital":  { "prefix": "/api/orbital",  "upstream": "http://space-service:5100",       "services": 8 },
      "escudo":   { "prefix": "/api/escudo",   "upstream": "http://military-service:5200",    "services": 5 },
      "cerebro":  { "prefix": "/api/cerebro",  "upstream": "http://education-service:5300",   "services": 4 },
      "tesoro":   { "prefix": "/api/tesoro",   "upstream": "http://commerce-service:5400",    "services": 8 },
      "voces":    { "prefix": "/api/voces",    "upstream": "http://media-service:5500",       "services": 5 },
      "consejo":  { "prefix": "/api/consejo",  "upstream": "http://governance-service:5600",  "services": 5 },
      "tierra":   { "prefix": "/api/tierra",   "upstream": "http://agriculture-service:5700", "services": 5 },
      "forja":    { "prefix": "/api/forja",    "upstream": "http://devops-service:5800",      "services": 5 },
      "urbe":     { "prefix": "/api/urbe",     "upstream": "http://urban-service:5900",       "services": 4 },
      "raices":   { "prefix": "/api/raices",   "upstream": "http://identity-service:6000",    "services": 4 }
    }
  },
  "cache": {
    "provider": "redis",
    "redis": {
      "host": "redis-ierahkwa",
      "port": 6379,
      "db": 0,
      "keyPrefix": "mamey:",
      "maxRetries": 3,
      "retryDelay": 1000,
      "cluster": {
        "enabled": false,
        "nodes": []
      }
    },
    "ttl": {
      "default": 300,
      "static": 86400,
      "api": 60,
      "session": 3600
    }
  },
  "logging": {
    "level": "info",
    "format": "json",
    "transports": [
      { "type": "console", "colorize": true },
      { "type": "file", "path": "/var/log/ierahkwa/mameynode.log", "maxSize": "100MB", "maxFiles": 10 },
      { "type": "elasticsearch", "host": "es-ierahkwa:9200", "index": "mameynode-logs" }
    ],
    "requestLogging": {
      "enabled": true,
      "excludePaths": ["/health", "/ready", "/metrics"],
      "includeHeaders": false,
      "includeBody": false,
      "slowRequestThreshold": 3000
    }
  },
  "monitoring": {
    "prometheus": {
      "enabled": true,
      "path": "/metrics",
      "port": 9090,
      "defaultLabels": { "platform": "ierahkwa", "runtime": "mameynode" },
      "collectDefaultMetrics": true,
      "buckets": [0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1, 2.5, 5, 10]
    },
    "healthCheck": {
      "path": "/health",
      "detailed": "/health/detailed",
      "dependencies": ["redis", "database", "gateway"]
    },
    "tracing": {
      "enabled": true,
      "provider": "opentelemetry",
      "exporter": "jaeger",
      "jaegerEndpoint": "http://jaeger-ierahkwa:14268/api/traces",
      "sampleRate": 0.1
    }
  },
  "security": {
    "helmet": true,
    "compression": true,
    "trustProxy": true,
    "jwt": {
      "issuer": "ierahkwa-auth",
      "audience": "ierahkwa-platform",
      "algorithm": "RS256",
      "publicKeyPath": "/etc/ierahkwa/keys/jwt-public.pem",
      "expiresIn": "1h",
      "refreshExpiresIn": "7d"
    },
    "csrf": {
      "enabled": true,
      "cookieName": "_ierahkwa_csrf",
      "headerName": "X-CSRF-Token"
    },
    "contentSecurityPolicy": {
      "defaultSrc": ["'self'"],
      "scriptSrc": ["'self'", "'unsafe-inline'"],
      "styleSrc": ["'self'", "'unsafe-inline'"],
      "imgSrc": ["'self'", "data:", "https://*.ierahkwa.io"],
      "connectSrc": ["'self'", "https://*.ierahkwa.io", "wss://*.ierahkwa.io"],
      "fontSrc": ["'self'"],
      "objectSrc": ["'none'"],
      "frameAncestors": ["'self'"]
    }
  },
  "database": {
    "primary": {
      "provider": "postgresql",
      "host": "pg-ierahkwa",
      "port": 5432,
      "database": "ierahkwa_main",
      "ssl": true,
      "pool": { "min": 5, "max": 50, "idleTimeout": 30000 }
    },
    "readonly": {
      "provider": "postgresql",
      "host": "pg-ierahkwa-readonly",
      "port": 5432,
      "database": "ierahkwa_main",
      "ssl": true,
      "pool": { "min": 5, "max": 100, "idleTimeout": 30000 }
    }
  },
  "i18n": {
    "defaultLocale": "es",
    "supportedLocales": ["es", "en", "nah", "quz", "grn", "ay", "myn", "map", "che"],
    "fallbackLocale": "es",
    "localesPath": "/etc/ierahkwa/locales"
  },
  "sovereignty": {
    "dataResidency": "indigenous-territory",
    "jurisdictions": ["tribal-nations", "autonomous-regions"],
    "compliance": ["UNDRIP", "ILO-169", "GDPR-equivalent"],
    "encryption": {
      "atRest": "AES-256-GCM",
      "inTransit": "TLS-1.3",
      "keyManagement": "ierahkwa-kms"
    }
  }
}
