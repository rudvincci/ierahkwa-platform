# ============================================================
# SOVEREIGN PLATFORM — Environment Configuration
# Ierahkwa Ne Kanienke Digital Nation
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Database (PostgreSQL 16) ─────────────────────────────────
# Used by: postgres container + all Node.js / .NET services
POSTGRES_USER=ierahkwa
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_RANDOM_64_CHARS
POSTGRES_DB=ierahkwa_sovereign
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── Authentication (JWT) ─────────────────────────────────────
# Shared secret for HS256 token signing across services.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_128_CHARS

# Identity service JWT (used by bdet-bank container)
IDENTITY_JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_128_CHARS
IDENTITY_JWT_ISSUER=ierahkwa.sovereign

# Session secret (used by express-session where applicable)
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# ── Security ─────────────────────────────────────────────────
DEFAULT_ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=admin@ierahkwa.gov
ADMIN_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────
# Used by: bdet-bank, voz-soberana, red-social, reservas,
#          trading, pos-system, ierahkwa-shop, forex-trading
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── General ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MameyNode Blockchain ────────────────────────────────────
MAMEYNODE_RPC=http://127.0.0.1:8545
MAMEYNODE_CHAIN_ID=777777
MAMEYNODE_VERSION=4.2

# ── WAMPUM Token ─────────────────────────────────────────────
WAMPUM_CONTRACT_ADDRESS=0x_CHANGE_ME
WAMPUM_DECIMALS=18
SICBDC_CONTRACT_ADDRESS=0x_CHANGE_ME

# ── Email (SMTP) ────────────────────────────────────────────
# Used by: correo-soberano, sovereign-core
SMTP_HOST=localhost
SMTP_PORT=587

# ============================================================
# .NET Services
# ============================================================

# Identity Service (port 5001)
IDENTITY_SERVICE_URL=http://127.0.0.1:5001

# ZKP Service (port 5002)
ZKP_SERVICE_URL=http://127.0.0.1:5002

# Treasury Service (port 5003)
TREASURY_SERVICE_URL=http://127.0.0.1:5003

# ============================================================
# Node.js Services — Original (ports 3001-3007)
# ============================================================

# BDET Bank (port 3001)
BDET_API_URL=http://127.0.0.1:3001
BDET_API_KEY=CHANGE_THIS_API_KEY

# Voz Soberana — Microblogging (port 3002)
VOZ_SOBERANA_URL=http://127.0.0.1:3002

# Red Social (port 3003)
RED_SOCIAL_URL=http://127.0.0.1:3003

# Correo Soberano — Email (port 3004)
CORREO_URL=http://127.0.0.1:3004

# Reservas (port 3005)
RESERVAS_URL=http://127.0.0.1:3005

# Voto Soberano (port 3006)
VOTO_URL=http://127.0.0.1:3006

# Trading (port 3007)
TRADING_URL=http://127.0.0.1:3007

# ============================================================
# Node.js Services — Extended (ports 3030+)
# ============================================================

# POS System (port 3030)
POS_SYSTEM_URL=http://127.0.0.1:3030
POS_SYSTEM_PORT=3030

# Ierahkwa Shop — E-commerce (port 3100)
IERAHKWA_SHOP_URL=http://127.0.0.1:3100
IERAHKWA_SHOP_PORT=3100

# Inventory System (port 3200)
INVENTORY_URL=http://127.0.0.1:3200
INVENTORY_PORT=3200

# Image Upload Service (port 3300)
IMAGE_UPLOAD_URL=http://127.0.0.1:3300
IMAGE_UPLOAD_PORT=3300

# Forex Trading Server (port 3400)
FOREX_URL=http://127.0.0.1:3400
FOREX_PORT=3400

# Smart School (port 3500)
SMART_SCHOOL_URL=http://127.0.0.1:3500
SMART_SCHOOL_PORT=3500

# ============================================================
# Node.js Services — Sovereign Open-Source (ports 3050, 3090+)
# ============================================================

# Sovereign Core — Universal Backend (port 3050)
SOVEREIGN_CORE_URL=http://127.0.0.1:3050

# Conferencia Soberana — Video Conferencing (port 3090)
CONFERENCIA_URL=http://127.0.0.1:3090

# Vigilancia Soberana — SIEM (port 3091)
VIGILANCIA_URL=http://127.0.0.1:3091

# Empresa Soberana — ERP (port 3092)
EMPRESA_URL=http://127.0.0.1:3092

# ============================================================
# Sovereign Configuration
# ============================================================

SOVEREIGN_DNS=ns1.soberano.local
SOVEREIGN_MAIL=mail.soberano.local
SOVEREIGN_DOMAIN=soberano.bo

# TLS Certificates (development)
TLS_CERT_PATH=/etc/mamey/tls/server.crt
TLS_KEY_PATH=/etc/mamey/tls/server.key

# ============================================================
# Monitoring
# ============================================================

PROMETHEUS_URL=http://127.0.0.1:9090
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ============================================================
# AI & Translation
# ============================================================

# Atabey Translator
ATABEY_LANGUAGES=quechua,aymara,guarani,taino,maya,nahuatl,mapudungun,wayuu,kuna,miskitu,garifuna,bribri,kalinago,arawak

# MameyFutureAI
AI_ENGINE_COUNT=42
AI_SERVICE_URL=http://127.0.0.1:5100

# ============================================================
# API Configuration
# ============================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# Backup
# ============================================================

BACKUP_DRIVE_PATH=/Volumes/Extreme Pro
BACKUP_ENCRYPTION_KEY=CHANGE_ME
