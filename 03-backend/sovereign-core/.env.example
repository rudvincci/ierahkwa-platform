# ============================================================
# Ierahkwa Sovereign Core — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3050
HOST=0.0.0.0

# ── Database (PostgreSQL) ────────────────────────────────────
# REQUIRED in production
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/sovereign_core
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000

# ── Authentication (JWT) ─────────────────────────────────────
# REQUIRED in production — minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── CORS ─────────────────────────────────────────────────────
# REQUIRED in production — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,video/mp4

# ── Email (SMTP / Nodemailer) ────────────────────────────────
SMTP_HOST=smtp.ierahkwa.gov
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ierahkwa.gov

# ── WebSocket ────────────────────────────────────────────────
ENABLE_WEBSOCKET=true
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_PAYLOAD=65536

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Sovereign Network ───────────────────────────────────────
SOVEREIGN_NODE_ID=mameynode-core-001
BLOCKCHAIN_RPC=http://localhost:8545
NATION_CODE=IK

# ── Feature Flags ────────────────────────────────────────────
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOG=true
ENABLE_EMAIL_NOTIFICATIONS=false
MAINTENANCE_MODE=false
