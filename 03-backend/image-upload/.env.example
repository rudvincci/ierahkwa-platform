# ============================================================
# Ierahkwa Image Upload Service — Environment Variables
# File upload with Dropzone, Drag&Drop, Thumbnails
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3300

# ── MinIO / S3 Object Storage ───────────────────────────────
# Endpoint URL for MinIO or S3-compatible storage
MINIO_ENDPOINT=http://localhost:9000

# Access credentials for object storage
MINIO_ACCESS_KEY=your-access-key-here
MINIO_SECRET_KEY=your-secret-key-here

# Bucket name for uploaded images
MINIO_BUCKET=ierahkwa-uploads

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Upload Limits ────────────────────────────────────────────
# Maximum file size in bytes (default: 10MB = 10485760)
MAX_FILE_SIZE=10485760
