# ============================================================
# Ierahkwa API Gateway — Environment Variables
# Central gateway with JWT auth, circuit breakers, audit trail
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Authentication (JWT — HS256 / RS256) ─────────────────────
# Provide JWT_SECRET for HS256 symmetric signing, or
# JWT_PUBLIC_KEY for RS256 asymmetric verification.
# At least one MUST be set in production.
# Generate HS256 secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# Optional: PEM-encoded RSA public key for RS256 verification
# JWT_PUBLIC_KEY=

# Expected issuer claim in JWT tokens
JWT_ISSUER=ierahkwa

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Note: this service uses CORS_ORIGIN (singular) not CORS_ORIGINS.
CORS_ORIGIN=https://ierahkwa.gov,https://app.ierahkwa.gov

# ── Rate Limiting ────────────────────────────────────────────
# Maximum requests per IP within the duration window.
RATE_LIMIT_POINTS=200
# Duration window in seconds.
RATE_LIMIT_DURATION=60
