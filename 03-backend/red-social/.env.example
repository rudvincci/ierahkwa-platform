# ============================================================
# Red Social — Environment Variables
# Social network: posts, chat, trading (BDET Bank 11 engines)
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development

# ── Server Port ──────────────────────────────────────────────
# Note: this service uses BDET_PORT (not PORT) for historical reasons.
BDET_PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────
# Connection string for the social/trading database.
# Tables: posts, conversations, messages, trading_orders, trades
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/red_social

# ── Redis ────────────────────────────────────────────────────
# Used for caching and real-time pub/sub (WebSocket market feed).
# In docker-compose this is provided as REDIS_URL.
REDIS_URL=redis://localhost:6379
