# ============================================================
# Conferencia Soberana — Environment Variables
# Sovereign Video Conferencing (WebRTC + Socket.IO)
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3090

# ── Database (PostgreSQL) ────────────────────────────────────
# Connection string for the conferencing database.
# Tables: rooms, participants
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/conferencia_soberana

# Database pool maximum connections
DB_POOL_MAX=10

# ── Authentication (JWT) ─────────────────────────────────────
# Secret for verifying JWT bearer tokens (required in production).
# Must match the secret used by the identity / auth service.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Also used for Socket.IO CORS configuration.
CORS_ORIGINS=http://localhost:3000

# ── TURN Server (WebRTC relay) ───────────────────────────────
# Optional. Required for NAT traversal in production.
TURN_SERVER_URL=turn:turn.soberano.sovereign:3478
TURN_USERNAME=soberano
TURN_CREDENTIAL=sovereign-credential
