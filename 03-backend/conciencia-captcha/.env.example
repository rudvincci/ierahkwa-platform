# ============================================================
# Ierahkwa Conciencia Captcha — Environment Variables
# Captcha Semantico-Empatico v11.0.0-PHANTOM
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3099

# ── Ollama AI Mediator ──────────────────────────────────────
# URL of the Ollama instance for empathy analysis
OLLAMA_URL=http://ollama:11434

# LLM model to use for empathy evaluation
OLLAMA_MODEL=mistral

# ── Empathy Configuration ───────────────────────────────────
# Minimum empathy score (0.0-1.0) required to pass captcha
# Users scoring below this threshold are blocked as bots
EMPATHY_THRESHOLD=0.8
