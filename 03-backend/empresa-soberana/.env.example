# ============================================================
# Empresa Soberana — Environment Variables
# Sovereign ERP: CRM, Inventory, Invoicing
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3092

# ── Database (PostgreSQL) ────────────────────────────────────
# Connection string for the ERP database.
# Tables: contacts, products, invoices
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/empresa_soberana

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In docker-compose defaults to http://localhost:3092
CORS_ORIGINS=http://localhost:3092
