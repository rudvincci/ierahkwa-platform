# ============================================================
# Voto Soberano — Environment Variables
# Sovereign voting backend with SHA-256 ballot chain integrity
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3006

# ── Database (PostgreSQL) ────────────────────────────────────
# Connection string for the voting database.
# In docker-compose this is constructed from POSTGRES_USER/POSTGRES_PASSWORD.
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/voto_soberano

# Pool tuning (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Authentication (JWT) ─────────────────────────────────────
# Secret for verifying JWT bearer tokens.
# Must match the secret used by the identity / auth service.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# ── Blockchain ───────────────────────────────────────────────
# MameyNode RPC endpoint for on-chain vote anchoring (optional)
MAMEYNODE_RPC=http://localhost:8545
