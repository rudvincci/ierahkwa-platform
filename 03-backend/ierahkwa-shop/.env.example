# ============================================================
# Ierahkwa Futurehead Shop — Environment Variables
# E-Commerce + POS + Inventory + Chat (Socket.IO)
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3100

# ── Database ─────────────────────────────────────────────────
# Connection string for the shop database
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/ierahkwa_shop

# ── Authentication ──────────────────────────────────────────
# Secret key for JWT token signing — minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-here

# ── Admin Credentials ───────────────────────────────────────
# Default admin login — CHANGE IN PRODUCTION
ADMIN_EMAIL=admin@ierahkwa.gov
ADMIN_PASSWORD=your-admin-password-here

# ── MameyNode Blockchain ────────────────────────────────────
# RPC endpoint for MameyNode sovereign blockchain (Chain ID 574)
MAMEYNODE_RPC=http://localhost:8545

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins for Socket.IO and REST API
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
