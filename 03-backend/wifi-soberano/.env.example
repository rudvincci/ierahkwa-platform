# WiFi Soberano — Environment Configuration
# Copy to .env and fill in values

# Server
PORT=3095
NODE_ENV=production
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://ierahkwa:ierahkwa@postgres:5432/wifi_soberano

# Redis (sessions + real-time)
REDIS_URL=redis://redis:6379

# JWT Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGINS=https://ierahkwa.nation,https://wifi.ierahkwa.nation

# WAMPUM Payments (MameyNode)
MAMEYNODE_RPC_URL=http://mameynode:8545
WAMPUM_CONTRACT_ADDRESS=0x...
BDET_BANK_API=http://sovereign-core:3050/api/v1/bank

# Vigilancia Soberana
VIGILANCIA_ENABLED=true
VIP_ALERT_WEBHOOK=https://api.ierahkwa.nation/alerts/vip
ATABEY_AI_ENDPOINT=http://sovereign-core:3050/api/v1/atabey

# GeoIP
GEOIP_DB_PATH=/data/geoip/GeoLite2-City.mmdb

# Starlink Fleet API (internal)
FLEET_SYNC_INTERVAL=60000
