# ============================================================
# Ierahkwa POS System — Environment Variables
# Smart POS + CRM + Inventory Management
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3030

# ── Database ─────────────────────────────────────────────────
# Connection string for the POS database
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/ierahkwa_pos

# ── Session ──────────────────────────────────────────────────
# Secret key for express-session — minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-session-secret-here
