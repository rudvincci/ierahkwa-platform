# ============================================================
# Vigilancia Soberana — Environment Variables
# Sovereign SIEM / Security Information & Event Management
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3091

# ── Database (PostgreSQL) ────────────────────────────────────
# Connection string for the SIEM database.
# Tables: events, alert_rules, triggered_alerts,
#          compliance_frameworks, compliance_controls, counters
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/vigilancia_soberana

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In docker-compose defaults to http://localhost:3091
CORS_ORIGINS=http://localhost:3091
