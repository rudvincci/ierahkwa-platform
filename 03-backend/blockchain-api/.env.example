# ============================================================
# Ierahkwa Blockchain API — Environment Variables
# MameyNode v4.2 — Red Soberana Blockchain
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── MameyNode Blockchain ────────────────────────────────────
# RPC endpoint for MameyNode sovereign blockchain
MAMEYNODE_RPC=http://localhost:8545

# WebSocket endpoint for real-time block/tx subscriptions
MAMEYNODE_WS=ws://localhost:8546

# Sovereign chain identifier (574 = Ierahkwa Nation)
CHAIN_ID=574

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
