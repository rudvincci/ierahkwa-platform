# ============================================================
# Ierahkwa ML Engine — Environment Variables
# Sovereign AI/ML: Trust, Anomaly, Pattern, Swarm
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3400
HOST=0.0.0.0

# ── AI Fortress ─────────────────────────────────────────────
# URL of the AI Fortress orchestration service
AI_FORTRESS_URL=http://localhost:3080

# ── CORS ─────────────────────────────────────────────────────
# Allowed origin for cross-origin requests (* for development)
CORS_ORIGIN=http://localhost:3000

# ── Trust Engine ─────────────────────────────────────────────
# Rate at which trust score decays over time (0.0-1.0)
TRUST_DECAY_RATE=0.02

# Magnitude of trust boost per positive event (0.0-1.0)
TRUST_BOOST_RATE=0.5

# ── Anomaly Detector ────────────────────────────────────────
# Number of data points in the sliding window
ANOMALY_WINDOW=100

# Z-score threshold for statistical anomaly detection
ANOMALY_Z_THRESHOLD=2.5

# Exponential moving average smoothing factor (0.0-1.0)
ANOMALY_EMA_ALPHA=0.1

# IQR multiplier for interquartile range outlier detection
ANOMALY_IQR_MULT=1.5
