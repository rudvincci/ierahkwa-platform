# ============================================================
# Ierahkwa Futurehead — Forex Trading Server
# Real-time Trading, Sovereign Economy (WPM, IGT, BDET, SNT-574)
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
PORT=3500

# ── Sovereign Core ──────────────────────────────────────────
# URL of the Sovereign Core API service
SOVEREIGN_CORE_URL=http://localhost:3050

# ── MameyNode Blockchain ────────────────────────────────────
# RPC endpoint for MameyNode sovereign blockchain (Chain ID 574)
MAMEYNODE_RPC=http://localhost:8545

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins for Socket.IO and REST API
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Redis (optional — for session and caching) ──────────────
REDIS_URL=redis://localhost:6379

# ── MongoDB (optional — for trade persistence) ──────────────
MONGODB_URI=mongodb://localhost:27017/ierahkwa-forex

# ── Authentication ──────────────────────────────────────────
# Secret key for JWT token signing
JWT_SECRET=your-secret-here
