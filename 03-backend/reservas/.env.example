# ============================================================
# Ierahkwa Reservas (SoberanoServicios) — Environment Variables
# Booking, Providers, Services — 92% to providers, 0% taxes
# Copy this file to .env and fill in your values
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production

# ── Server Port ──────────────────────────────────────────────
# Note: this service uses SERVICIOS_PORT (not PORT)
SERVICIOS_PORT=3005

# ── Database ─────────────────────────────────────────────────
# Connection string for the reservations database
DATABASE_URL=postgresql://ierahkwa:password@localhost:5432/ierahkwa_reservas
