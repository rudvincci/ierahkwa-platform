    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#43a047", "mode": "shades" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }, "unit": "reqps" } },
