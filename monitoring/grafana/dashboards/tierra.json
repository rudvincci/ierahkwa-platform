      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"tierra-.*\", status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"tierra-.*\"}[5m])) by (job)", "legendFormat": "{{job}}" }],
      "title": "5xx Error Rate by Service",
      "type": "timeseries"
    },
