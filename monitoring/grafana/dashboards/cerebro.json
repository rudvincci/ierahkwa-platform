      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{namespace=\"$namespace\", job=\"cerebro-search\"}", "legendFormat": "search" }],
      "title": "search :5303",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "title": "Request Rate",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#7c4dff", "mode": "shades" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"cerebro-.*\"}[5m])) by (job)", "legendFormat": "{{job}}" }],
      "title": "HTTP Request Rate by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"cerebro-.*\"}[5m])) by (le, job))", "legendFormat": "p50 {{job}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"cerebro-.*\"}[5m])) by (le, job))", "legendFormat": "p95 {{job}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"cerebro-.*\"}[5m])) by (le, job))", "legendFormat": "p99 {{job}}" }
      ],
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 30,
      "title": "Error Rate",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 20 }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"cerebro-.*\", status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"cerebro-.*\"}[5m])) by (job)", "legendFormat": "{{job}}" }],
      "title": "5xx Error Rate by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 40,
      "title": "Resource Usage",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"cerebro-.*\"}[5m])) by (pod) * 100", "legendFormat": "{{pod}}" }],
      "title": "CPU Usage per Pod",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 42,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"cerebro-.*\"}) by (pod)", "legendFormat": "{{pod}}" }],
      "title": "Memory Usage per Pod",
      "type": "timeseries"
    },
