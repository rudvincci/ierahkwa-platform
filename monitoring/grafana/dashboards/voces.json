      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#e040fb", "mode": "shades" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }, "unit": "reqps" } },
