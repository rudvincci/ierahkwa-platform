      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{namespace=\"$namespace\", job=\"urbe-postalmaps\"}", "legendFormat": "postalmaps" }],
