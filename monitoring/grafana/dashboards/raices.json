{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [{ "title": "Back to Overview", "url": "/d/nexus-overview", "type": "link" }],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Service Health - Raices Domain (4 services, ports 6000-6003)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "#d4a853", "text": "UP" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#d4a853", "value": 1 }] } } },
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{namespace=\"$namespace\", job=\"raices-identity\"}", "legendFormat": "identity" }],
      "title": "identity :6000",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "#d4a853", "text": "UP" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#d4a853", "value": 1 }] } } },
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{namespace=\"$namespace\", job=\"raices-health\"}", "legendFormat": "health" }],
      "title": "health :6001",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "#d4a853", "text": "UP" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#d4a853", "value": 1 }] } } },
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{namespace=\"$namespace\", job=\"raices-nexusaggregation\"}", "legendFormat": "nexusaggregation" }],
      "title": "nexusaggregation :6002",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "#d4a853", "text": "UP" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#d4a853", "value": 1 }] } } },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{namespace=\"$namespace\", job=\"raices-licensing\"}", "legendFormat": "licensing" }],
      "title": "licensing :6003",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "title": "Request Rate",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#d4a853", "mode": "shades" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"raices-.*\"}[5m])) by (job)", "legendFormat": "{{job}}" }],
      "title": "HTTP Request Rate by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"raices-.*\"}[5m])) by (le, job))", "legendFormat": "p50 {{job}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"raices-.*\"}[5m])) by (le, job))", "legendFormat": "p95 {{job}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"raices-.*\"}[5m])) by (le, job))", "legendFormat": "p99 {{job}}" }
      ],
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 30,
      "title": "Error Rate",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 20 }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"raices-.*\", status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"raices-.*\"}[5m])) by (job)", "legendFormat": "{{job}}" }],
      "title": "5xx Error Rate by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 40,
      "title": "Resource Usage",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"raices-.*\"}[5m])) by (pod) * 100", "legendFormat": "{{pod}}" }],
      "title": "CPU Usage per Pod",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 42,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"raices-.*\"}) by (pod)", "legendFormat": "{{pod}}" }],
      "title": "Memory Usage per Pod",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 50,
      "title": "Raices Domain - Identity & Foundation Metrics",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#d4a853", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 15 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 51,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "raices_identity_verifications_total{namespace=\"$namespace\"}", "legendFormat": "Identity Verifications" },
        { "expr": "raices_identity_active_sessions{namespace=\"$namespace\"}", "legendFormat": "Active Identity Sessions" },
        { "expr": "raices_licensing_issued_total{namespace=\"$namespace\"}", "legendFormat": "Licenses Issued" }
      ],
      "title": "Identity & Licensing Activity",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#d4a853", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 15 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 52,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "raices_health_consultations_total{namespace=\"$namespace\"}", "legendFormat": "Health Consultations" },
        { "expr": "raices_health_patients_active{namespace=\"$namespace\"}", "legendFormat": "Active Patients" },
        { "expr": "raices_nexusaggregation_events_processed{namespace=\"$namespace\"}", "legendFormat": "Aggregation Events" }
      ],
      "title": "Health & Platform Aggregation",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ierahkwa", "nexus", "raices"],
